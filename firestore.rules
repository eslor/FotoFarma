rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.keys().size() >= 2 && data.keys().size() <= 8 &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256;
    }

    function isValidReminder(data) {
      return data.keys().hasAll(['uid', 'name', 'time', 'date']) &&
             data.keys().size() >= 4 && data.keys().size() <= 10 &&
             data.uid is string && data.uid.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.time is string && data.time.matches('^\\d{2}:\\d{2}$') &&
             data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
             (!('dosage' in data) || (data.dosage is string && data.dosage.size() <= 200)) &&
             (!('completed' in data) || data.completed is bool);
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) &&
                    incoming().uid == existing().uid;
    }

    match /reminders/{reminderId} {
      // Secure list query
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow get: if isSignedIn() && resource.data.uid == request.auth.uid;
      
      allow create: if isVerified() && isValidReminder(incoming()) && 
                    isOwner(incoming().uid);
      
      allow update: if isOwner(existing().uid) && (
        // Action: Toggle Complete
        (incoming().diff(existing()).affectedKeys().hasOnly(['completed']) && isValidReminder(incoming())) ||
        // Action: Edit Full
        (isValidReminder(incoming()) && incoming().uid == existing().uid)
      );
      
      allow delete: if isOwner(existing().uid);
    }

    match /prescriptions/{prescriptionId} {
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow get: if isSignedIn() && resource.data.uid == request.auth.uid;
      
      allow create: if isVerified() && incoming().uid == request.auth.uid;
      allow delete: if isOwner(existing().uid);
    }

    // push_subscriptions is server-managed via Admin SDK, 
    // but we can add rules if the client ever needs to check subscription status.
    match /push_subscriptions/{subId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      // Write is handled by server, so we deny client writes for safety.
      allow write: if false;
    }
  }
}
