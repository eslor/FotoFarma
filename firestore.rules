rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.keys().size() >= 2 && data.keys().size() <= 8 &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256;
    }

    function isValidReminder(data) {
      return data.keys().hasAll(['uid', 'name', 'time', 'date']) &&
             data.keys().size() >= 4 && data.keys().size() <= 10 &&
             data.uid is string && data.uid.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.time is string && data.time.matches('^\\d{2}:\\d{2}$') &&
             data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
             (!('dosage' in data) || (data.dosage is string && data.dosage.size() <= 200)) &&
             (!('completed' in data) || data.completed is bool);
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) &&
                    incoming().uid == existing().uid;
    }

    match /reminders/{document=**} {
      allow read, write: if true; 
    }

    match /prescriptions/{document=**} {
      allow read, write: if true;
    }

    match /push_subscriptions/{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
